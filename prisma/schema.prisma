generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusEnvio {
  PENDENTE
  PROCESSANDO
  REENVIANDO

  PROCESSADO
  ENVIADO

  ERRO
  ERRO_ENVIO
  ERRO_PDF

  SEM_TELEFONE
  FUNCIONARIO_NAO_ENCONTRADO
  NOME_DIVERGENTE

  DUPLICADO_HASH
  DUPLICADO_COMPETENCIA
}

model Funcionario {

  cpf String @id

  codigo Int @unique

  nome String

  telefone String?

  email String?

  ativo Boolean @default(true)

  ultimaSincronizacao DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

}

model Envio {

  id Int @id @default(autoincrement())

  codigoFuncionario Int?

  cpf String?

  competencia String?

  nomeFuncionario String?

  telefone String?

  arquivoPdf String

  hashArquivo String? @unique

  status StatusEnvio @default(PENDENTE)

  mensagemErro String?

  jobId String?

  tentativas Int @default(0)

  ultimaTentativaEnvio DateTime?

  ultimoErro String?

  dataProcessamento DateTime @default(now())

  dataEnvio DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt

  @@unique([cpf, competencia])

}